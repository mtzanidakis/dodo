# AES-256-GCM key for encrypting secrets at rest, e.g. telegram bot tokens
# (required). Generate with:  openssl rand -base64 32
DODO_ENCRYPTION_KEY=

# Timezone (optional, default: UTC)
TZ=UTC

# UI defaults (optional)
#DODO_DEFAULT_TIMEZONE=Europe/Athens
#DODO_DEFAULT_LOCALE=en
#DODO_LOG_LEVEL=info

# Production: Tailscale reverse proxy (compose.override.yaml-prod)
#HOSTNAME=dodo
#TS_AUTHKEY=tskey-auth-...
